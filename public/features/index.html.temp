<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<title>Features — three.ws</title>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="An embodied 3D AI agent — body, place, identity, memory."
		/>
		<meta name="theme-color" content="#000000" />

		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="/style.css" />
		<link rel="stylesheet" href="/features.css" />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="features-page">
		<header class="agent-page-header" style="justify-content: space-between">
			<div style="display:inline-flex;align-items:center">
				<a href="/" aria-label="Back to three.ws home">
					<img src="/three.svg" alt="three.ws" class="agent-header-logo" />
				</a>
				<nav class="agent-header-nav" aria-label="Primary">
					<a href="/discover">Discover</a>
					<a href="/create">Create</a>
					<a href="/features" aria-current="page">Features</a>
					<a href="/studio">Studio</a>
				</nav>
			</div>
		</header>
		<main class="features-main">
			<section class="features-hero">
				<h1 class="features-hero-title">A New Dimension of AI</h1>
				<p class="features-hero-subtitle">
					Explore the powerful features that make three.ws the most advanced platform for creating and interacting with 3D AI agents.
				</p>
			</section>
			<section class="features-grid" aria-label="Features">
				<div class="feature-card">
					<div class="feature-card-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.41 1.41L16.17 10H4v4h12.17l-5.58 5.59L12 21l8-8-8-8z"></path></svg>
					</div>
					<h2 class="feature-card-title">Advanced AI Integration</h2>
					<p class="feature-card-desc">
						Seamlessly connect your agents to leading AI models, including GPT-4, Claude, and Llama, for natural and intelligent conversations.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14.5A3.5 3.5 0 0 1 7.5 11H12a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H7.5A3.5 3.5 0 0 1 4 14.5z"></path><path d="m13 11-1-9"></path></svg>
					</div>
					<h2 class="feature-card-title">Dynamic 3D Avatars</h2>
					<p class="feature-card-desc">
						Bring your agents to life with customizable 3D avatars that support a wide range of animations and expressions.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
					</div>
					<h2 class="feature-card-title">On-Chain Identity</h2>
					<p class="feature-card-desc">
						Securely manage your agents' identities on the blockchain with support for ERC-8004 and other popular standards.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2z"></path><path d="M12 12a10 10 0 0 0-4.1 7.8c.2-.1.4-.2.6-.3.2-.1.4-.2.6-.4"></path></svg>
					</div>
					<h2 class="feature-card-title">Seamless Integration</h2>
					<p class="feature-card-desc">
						Easily embed your agents into any website or application with just a few lines of code.
					</p>
				</div>
			</section>
			<section class="features-community">
				<h2 class="features-community-title">Join the Community</h2>
				<p class="features-community-subtitle">
					Connect with other creators, share your work, and get help from the three.ws community.
				</p>
				<div class="features-community-links">
					<a href="https://discord.gg/your-discord" class="community-link" target="_blank" rel="noopener">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M2.698 3.033a2.698 2.698 0 0 1 2.698-2.698h13.208a2.698 2.698 0 0 1 2.698 2.698v13.208a2.698 2.698 0 0 1-2.698 2.698h-13.208a2.698 2.698 0 0 1-2.698-2.698V3.033zM8.536 13.92a.843.843 0 0 0-.843.843c0 .466.377.843.843.843a.843.843 0 0 0 .843-.843c0-.466-.377-.843-.843-.843zm6.928 0a.843.843 0 0 0-.843.843c0 .466.377.843.843.843a.843.843 0 0 0 .843-.843c0-.466-.377-.843-.843-.843z"></path></svg>
						<span>Join our Discord</span>
					</a>
					<a href="https://github.com/nirholas/3D-Agent" class="community-link" target="_blank" rel="noopener">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0a12 12 0 0 0-3.793 23.393c.6.111.82-.261.82-.578v-2.02c-3.338.724-4.043-1.61-4.043-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.652.242 2.873.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.217.694.824.578A12 12 0 0 0 12 0z"></path></svg>
						<span>View on GitHub</span>
					</a>
				</div>
			</section>
			<section class="features-cta">
				<h2 class="features-cta-title">Ready to get started?</h2>
				<p class="features-cta-subtitle">
					Create your first 3D AI agent in just a few minutes.
				</p>
				<a href="/create" class="features-cta-button">Create Agent</a>
			</section>
		</main>
		<footer class="h-footer">
			<div class="h-footer-inner">
				<p>© 2026 three.ws — All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>