  "known_issues": [
    {
      "id": "broken-fidget-slot",
      "description": "The 'fidget' agent slot maps to 'Fidget' but no clip by that name exists in manifest.json. The slot silently falls through to a partial-name search on the embedded GLB model. Fix: either add a Fidget FBX to animations.config.json and rebuild, or remap the slot to an existing clip.",
      "affected_file": "src/runtime/animation-slots.js"
    },
    {
      "id": "orphaned-source-fbx",
      "description": "6 FBX files in public/animations/ are never built into clips. See the 'orphaned_fbx' collection. Fix: add entries to scripts/animations.config.json and run build-animations.mjs.",
      "affected_file": "scripts/animations.config.json"
    },
    {
      "id": "unused-agent-hint-targets",
      "description": "Several animationHint values emitted by skills ('gesture', 'inspect', 'present', 'sign', 'curiosity', 'patience') have no matching clip or slot. They silently no-op on Avaturn models. Fix: either map them to existing clips in DEFAULT_ANIMATION_MAP or build dedicated clips.",
      "affected_file": "src/runtime/animation-slots.js"
    },
    {
