{
	"name": "@three-ws/sdk",
	"version": "0.1.0",
	"description": "Ship a cross-chain 3D AI agent with EVM + Solana identity, a chat panel, and discoverable .well-known endpoints.",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js",
			"default": "./dist/index.mjs"
		},
		"./permissions": {
			"types": "./dist/permissions.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js",
			"default": "./dist/index.mjs"
		},
		"./permissions/advanced": {
			"types": "./dist/permissions/advanced.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js",
			"default": "./dist/index.mjs"
		},
		"./styles": "./dist/styles.css"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "node build.mjs",
		"test": "node --test 'test/**/*.test.js'"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"erc-8004", "agent", "blockchain", "a2a", "mcp",
		"ethereum", "solana", "web3", "identity", "3d", "ai", "nft", "metaplex"
	],
	"license": "MIT",
	"peerDependencies": {
		"ethers": "^6.0.0",
		"@solana/web3.js": "^1.0.0"
	},
	"peerDependenciesMeta": {
		"ethers": { "optional": true },
		"@solana/web3.js": { "optional": true }
	}
}
