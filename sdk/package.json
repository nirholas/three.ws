{
	"name": "@three-ws/sdk",
	"version": "0.1.0",
	"description": "Ship a cross-chain 3D AI agent with EVM + Solana identity, a chat panel, and discoverable .well-known endpoints.",
	"type": "module",
	"main": "./src/index.js",
	"module": "./src/index.js",
	"types": "./src/index.d.ts",
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"import": "./src/index.js",
			"default": "./src/index.js"
		},
		"./permissions": {
			"types": "./src/permissions.d.ts",
			"import": "./src/permissions.js",
			"default": "./src/permissions.js"
		},
		"./permissions/advanced": {
			"types": "./src/permissions/advanced.d.ts",
			"import": "./src/permissions/advanced.js",
			"default": "./src/permissions/advanced.js"
		},
		"./styles": "./src/styles.css"
	},
	"files": [
		"src"
	],
	"scripts": {
		"test": "node --test 'test/**/*.test.js'"
	},
	"keywords": [
		"erc-8004", "agent", "blockchain", "a2a", "mcp",
		"ethereum", "solana", "web3", "identity", "3d", "ai", "nft", "metaplex"
	],
	"license": "MIT",
	"peerDependencies": {
		"ethers": "^6.0.0",
		"@solana/web3.js": "^1.0.0"
	},
	"peerDependenciesMeta": {
		"ethers": { "optional": true },
		"@solana/web3.js": { "optional": true }
	}
}
