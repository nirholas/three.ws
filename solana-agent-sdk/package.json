{
  "name": "@three-ws/solana-agent",
  "version": "0.1.0",
  "description": "Solana agent SDK — keypair + browser wallet, transfers, swaps, x402 exact scheme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./wallet": {
      "types": "./dist/wallet/index.d.ts",
      "import": "./dist/wallet/index.js",
      "require": "./dist/wallet/index.cjs"
    },
    "./x402-exact": {
      "types": "./dist/x402-exact/index.d.ts",
      "import": "./dist/x402-exact/index.js",
      "require": "./dist/x402-exact/index.cjs"
    },
    "./solana-agent-kit": {
      "types": "./dist/solana-agent-kit/index.d.ts",
      "import": "./dist/solana-agent-kit/index.js",
      "require": "./dist/solana-agent-kit/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:prod": "tsup --minify",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run typecheck && npm run build:prod",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "zod": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
