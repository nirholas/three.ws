{
	"private": true,
	"type": "module",
	"version": "1.5.1",
	"name": "3d-agent",
	"description": "AI-powered 3D model viewer — drag-and-drop glTF/GLB preview tool.",
	"author": "nirholas",
	"license": "Apache-2.0",
	"overrides": {
		"serialize-javascript": ">=7.0.5"
	},
	"keywords": [
		"3d-viewer",
		"gltf-viewer",
		"glb-viewer",
		"3d-model-viewer",
		"webgl",
		"threejs",
		"drag-and-drop",
		"3d-agent"
	],
	"main": "src/app.js",
	"browserslist": [
		">1%",
		"not dead"
	],
	"staticFiles": {
		"staticPath": [
			{
				"staticPath": "assets",
				"staticOutDir": "assets"
			}
		]
	},
	"scripts": {
		"dev": "vite --port 3000",
		"dev:lib": "TARGET=lib vite",
		"build": "vite build",
		"build:animations": "node scripts/build-animations.mjs",
		"build:lib": "TARGET=lib vite build",
		"build:artifact": "vite build --config vite.config.artifact.js",
		"publish:lib": "node scripts/publish-lib.mjs",
		"build:all": "npm run build && npm run build:lib && npm run publish:lib",
		"clean": "rm -rf dist/* dist-lib/* || true",
		"generate-icons": "node scripts/generate-pwa-icons.mjs",
		"fetch-animations": "node scripts/download-animations.mjs",
		"test": "vitest run",
		"verify": "prettier --check . && vite build",
		"format": "prettier --write .",
		"deploy": "npm run build:all && vercel --local-config vercel.json --prod",
		"postversion": "git push && git push --tags",
		"validate:cards": "node scripts/validate-agent-cards.mjs"
	},
	"dependencies": {
		"@avaturn/sdk": "^1.1.4",
		"@aws-sdk/client-s3": "^3.651.0",
		"@aws-sdk/s3-request-presigner": "^3.651.0",
		"@chenglou/pretext": "^0.0.5",
		"@gltf-transform/core": "^4.3.0",
		"@gltf-transform/extensions": "^4.3.0",
		"@metaplex-foundation/mpl-core": "^1.10.0",
		"@metaplex-foundation/umi": "^1.5.1",
		"@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
		"@neondatabase/serverless": "^0.10.1",
		"@noble/curves": "^2.2.0",
		"@sentry/node": "^10.50.0",
		"@solana/web3.js": "^1.98.4",
		"@upstash/ratelimit": "^2.0.5",
		"@upstash/redis": "^1.34.3",
		"bcryptjs": "^2.4.3",
		"bs58": "^6.0.0",
		"dat.gui": "^0.7.9",
		"ethers": "^6.16.0",
		"gltf-validator": "^2.0.0-dev.3.10",
		"jose": "^5.9.6",
		"query-string": "^8.1.0",
		"resend": "^6.12.2",
		"simple-dropzone": "^0.8.3",
		"three": "^0.176.0",
		"vhtml": "^2.2.0",
		"viem": "^2.18.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"playwright": "^1.59.1",
		"prettier": "^3.2.5",
		"sharp": "^0.34.5",
		"vite": "^7.3.2",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.4",
		"workbox-build": "^7.4.0",
		"workbox-window": "^7.4.0"
	}
}
