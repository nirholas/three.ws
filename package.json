{
	"private": true,
	"type": "module",
	"version": "1.5.1",
	"name": "3d-agent",
	"description": "AI-powered 3D model viewer — drag-and-drop glTF/GLB preview tool.",
	"author": "nirholas",
	"license": "MIT",
	"overrides": {
		"serialize-javascript": ">=7.0.5"
	},
	"keywords": [
		"3d-viewer",
		"gltf-viewer",
		"glb-viewer",
		"3d-model-viewer",
		"webgl",
		"threejs",
		"drag-and-drop",
		"3d-agent"
	],
	"main": "src/app.js",
	"browserslist": [
		">1%",
		"not dead"
	],
	"staticFiles": {
		"staticPath": [
			{
				"staticPath": "assets",
				"staticOutDir": "assets"
			}
		]
	},
	"scripts": {
		"dev": "vite --port 3000",
		"dev:lib": "TARGET=lib vite",
		"build": "vite build",
		"build:lib": "TARGET=lib vite build",
		"build:all": "npm run build && npm run build:lib",
		"clean": "rm -rf dist/* dist-lib/* || true",
		"generate-icons": "node scripts/generate-pwa-icons.mjs",
		"fetch-animations": "node scripts/download-animations.mjs",
		"test": "echo 'No tests configured' && exit 0",
		"deploy": "npm run build && vercel --local-config vercel.json --prod",
		"postversion": "git push && git push --tags"
	},
	"dependencies": {
		"@avaturn/sdk": "^0.7.0",
		"@aws-sdk/client-s3": "^3.651.0",
		"@aws-sdk/s3-request-presigner": "^3.651.0",
		"@chenglou/pretext": "^0.0.5",
		"@gltf-transform/core": "^4.3.0",
		"@gltf-transform/extensions": "^4.3.0",
		"@neondatabase/serverless": "^0.10.1",
		"@privy-io/js-sdk-core": "latest",
		"@upstash/ratelimit": "^2.0.5",
		"@upstash/redis": "^1.34.3",
		"bcryptjs": "^2.4.3",
		"dat.gui": "^0.7.9",
		"ethers": "^6.16.0",
		"gltf-validator": "^2.0.0-dev.3.10",
		"jose": "^5.9.6",
		"query-string": "^8.1.0",
		"simple-dropzone": "^0.8.3",
		"three": "^0.176.0",
		"vhtml": "^2.2.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"prettier": "^3.2.5",
		"sharp": "^0.34.5",
		"vite": "^8.0.8",
		"vite-plugin-pwa": "^1.2.0",
		"workbox-build": "^7.4.0",
		"workbox-window": "^7.4.0"
	}
}
