# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
# generate with: openssl rand -base64 32
AUTH_SECRET=""

# ---------- Database (Postgres) ----------
# Neon / Supabase / Railway / RDS — all work.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ---------- OAuth (Google) ----------
# https://console.cloud.google.com → Credentials → OAuth client ID (Web)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------- Magic-link email (Resend) ----------
# https://resend.com → API Keys
AUTH_RESEND_KEY=""
EMAIL_FROM="three.ws <noreply@three.ws>"

# ---------- Stripe ----------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Create a recurring Price in Stripe Dashboard, paste the price_... id here.
STRIPE_PRO_PRICE_ID="price_..."

# For local dev: run `pnpm stripe:listen` and paste the whsec_... it prints.
# For prod: create a webhook endpoint at /api/stripe/webhook in the dashboard.
STRIPE_WEBHOOK_SECRET="whsec_..."
