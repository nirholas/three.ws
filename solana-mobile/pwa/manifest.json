{
  "name": "three.ws — On-chain 3D Agents",
  "short_name": "three.ws",
  "description": "Mint a 3D agent to your Seed Vault wallet. Capture, customize, and explore — Solana-native, signed by Seeker.",
  "id": "/",
  "scope": "/",
  "start_url": "/?utm_source=seeker_dapp_store",
  "display": "standalone",
  "orientation": "any",
  "theme_color": "#000000",
  "background_color": "#080814",
  "lang": "en",
  "dir": "ltr",
  "categories": ["entertainment", "social", "graphics", "utilities"],
  "icons": [
    { "src": "/pwa-192x192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "/pwa-512x512.png", "sizes": "512x512", "type": "image/png" },
    { "src": "/pwa-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" },
    { "src": "/pwa-icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" }
  ],
  "shortcuts": [
    {
      "name": "Create avatar",
      "short_name": "Create",
      "description": "Capture a selfie and mint a 3D agent",
      "url": "/create?utm_source=seeker_shortcut",
      "icons": [{ "src": "/pwa-192x192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Discover agents",
      "short_name": "Discover",
      "description": "Browse 3D agents minted on Solana",
      "url": "/discover?utm_source=seeker_shortcut",
      "icons": [{ "src": "/pwa-192x192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "My agents",
      "short_name": "Account",
      "description": "View agents linked to your wallet",
      "url": "/account?utm_source=seeker_shortcut",
      "icons": [{ "src": "/pwa-192x192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/create",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        { "name": "selfie", "accept": ["image/jpeg", "image/png", "image/webp"] },
        { "name": "model", "accept": [".glb", ".gltf", "model/gltf-binary", "model/gltf+json"] }
      ]
    }
  },
  "protocol_handlers": [
    { "protocol": "web+threews", "url": "/?ref=%s" }
  ],
  "prefer_related_applications": false
}
