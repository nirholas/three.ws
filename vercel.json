{
	"public": true,
	"routes": [
		{
			"src": "/openapi\\.json",
			"dest": "/api/openapi-json"
		},
		{
			"src": "/\\.well-known/x402",
			"dest": "/api/wk-x402"
		},
		{
			"src": "/\\.well-known/oauth-authorization-server",
			"dest": "/api/wk-oauth-authorization-server"
		},
		{
			"src": "/\\.well-known/oauth-protected-resource",
			"dest": "/api/wk-oauth-protected-resource"
		},
		{
			"src": "/api/mcp/\\.well-known/oauth-protected-resource",
			"dest": "/api/wk-oauth-protected-resource"
		},

		{ "src": "/oauth/authorize", "dest": "/api/oauth/authorize" },
		{ "src": "/oauth/consent", "dest": "/api/oauth/authorize" },
		{ "src": "/oauth/token", "dest": "/api/oauth/token" },
		{ "src": "/oauth/register", "dest": "/api/oauth/register" },
		{ "src": "/oauth/revoke", "dest": "/api/oauth/revoke" },
		{ "src": "/oauth/introspect", "dest": "/api/oauth/introspect" },

		{ "src": "/login", "dest": "/login.html" },
		{ "src": "/register", "dest": "/register.html" },
		{ "src": "/forgot-password", "dest": "/forgot-password.html" },
		{ "src": "/reset-password", "dest": "/reset-password.html" },
		{ "src": "/wallet-login.js", "dest": "/wallet-login.js" },
		{ "src": "/wallet/(.*)", "dest": "/wallet/$1" },
		{ "src": "/deploy", "dest": "/app.html" },
		{ "src": "/dashboard", "dest": "/dashboard/index.html" },
		{ "src": "/dashboard/", "dest": "/dashboard/index.html" },
		{ "src": "/dashboard/(.*)", "dest": "/dashboard/$1" },
		{ "src": "/hydrate", "dest": "/hydrate/index.html" },
		{ "src": "/hydrate/", "dest": "/hydrate/index.html" },
		{ "src": "/studio", "dest": "/studio/index.html" },
		{ "src": "/studio/", "dest": "/studio/index.html" },
		{ "src": "/studio/(.*)", "dest": "/studio/$1" },

		{ "src": "/api/dashboard/prefs", "dest": "/api/dashboard/prefs" },
		{ "src": "/api/agents/me", "dest": "/api/agents" },
		{ "src": "/api/agents/suggest", "dest": "/api/agents/suggest" },
		{ "src": "/api/agents/by-wallet", "dest": "/api/agents/by-wallet" },
		{
			"src": "/api/agents/by-address/([^/]+)",
			"dest": "/api/agents/by-address/[addr]?addr=$1"
		},
		{ "src": "/api/agents/([^/]+)/wallet", "dest": "/api/agents/[id]" },
		{
			"src": "/api/avatars/([^/]+)/storage-mode",
			"dest": "/api/avatars/[id]/storage-mode?id=$1"
		},
		{ "src": "/api/avatars/([^/]+)/pin-ipfs", "dest": "/api/avatars/[id]/pin-ipfs?id=$1" },
		{ "src": "/dashboard/storage", "dest": "/dashboard/storage.html" },
		{
			"src": "/api/agents/([^/]+)/embed-policy",
			"dest": "/api/agents/[id]/embed-policy?id=$1"
		},
		{ "src": "/api/agents/([^/]+)/sign", "dest": "/api/agents/[id]/sign?id=$1" },
		{ "src": "/api/agents/([^/]+)/animations", "dest": "/api/agents/[id]/animations?id=$1" },
		{ "src": "/api/agents/([^/]+)/manifest", "dest": "/api/agents/[id]/manifest?id=$1" },
		{ "src": "/api/agents/([^/]+)", "dest": "/api/agents/[id]" },
		{ "src": "/api/agents", "dest": "/api/agents" },
		{ "src": "/api/agent-actions", "dest": "/api/agent-actions" },
		{ "src": "/api/agent-memory/([^/]+)", "dest": "/api/agent-memory" },
		{ "src": "/api/agent-memory", "dest": "/api/agent-memory" },
		{ "src": "/api/agent/([^/]+)/og", "dest": "/api/agent-og?id=$1" },
		{ "src": "/api/a/(\\d+)/(\\d+)/og", "dest": "/api/a-og?chain=$1&id=$2" },
		{ "src": "/api/oembed", "dest": "/api/agent-oembed" },
		{ "src": "/u/([^/]+)", "dest": "/profile.html" },
		{ "src": "/a/(\\d+)/(\\d+)/edit", "dest": "/a-edit.html" },
		{ "src": "/agent/([^/]+)/edit", "dest": "/agent-edit.html" },
		{
			"src": "/agent/([^/]+)/embed",
			"headers": {
				"content-security-policy": "frame-ancestors *",
				"x-content-type-options": "nosniff",
				"referrer-policy": "strict-origin-when-cross-origin",
				"permissions-policy": "microphone=(self), camera=(self), xr-spatial-tracking=*"
			},
			"dest": "/agent-embed.html"
		},
		{
			"src": "/agent/([^/]+)",
			"has": [{ "type": "query", "key": "_spa", "value": "1" }],
			"dest": "/agent-home.html"
		},
		{ "src": "/agent/([^/]+)", "dest": "/api/agent-page?id=$1" },
		{ "src": "/agent", "dest": "/agent-home.html" },

		{ "src": "/api/widgets/oembed", "dest": "/api/widgets/oembed" },
		{ "src": "/api/widgets/page", "dest": "/api/widgets/page" },
		{ "src": "/api/widgets/([A-Za-z0-9_-]+)/og", "dest": "/api/widgets/og?id=$1" },
		{ "src": "/api/widgets/([A-Za-z0-9_-]+)/view", "dest": "/api/widgets/view?id=$1" },
		{
			"src": "/api/widgets/([A-Za-z0-9_-]+)/duplicate",
			"dest": "/api/widgets/[id]/duplicate?id=$1"
		},
		{ "src": "/api/widgets/([A-Za-z0-9_-]+)/stats", "dest": "/api/widgets/[id]/stats?id=$1" },
		{ "src": "/api/widgets/([A-Za-z0-9_-]+)/chat", "dest": "/api/widgets/[id]/chat?id=$1" },
		{ "src": "/api/widgets", "dest": "/api/widgets" },
		{ "src": "/api/widgets/([A-Za-z0-9_-]+)", "dest": "/api/widgets/[id]?id=$1" },
		{ "src": "/w/([A-Za-z0-9_-]+)", "dest": "/api/widgets/page?id=$1" },
		{ "src": "/widgets", "dest": "/widgets-gallery/index.html" },
		{ "src": "/widgets/", "dest": "/widgets-gallery/index.html" },
		{ "src": "/widgets/(.*)", "dest": "/widgets-gallery/$1" },
		{ "src": "/docs", "dest": "/docs/index.html" },
		{ "src": "/docs/", "dest": "/docs/index.html" },
		{ "src": "/docs/widgets", "dest": "/docs-widgets.html" },
		{ "src": "/docs/(.*)", "dest": "/docs/$1" },

		{ "src": "/artifact", "dest": "/artifact/index.html" },
		{ "src": "/artifact/", "dest": "/artifact/index.html" },
		{ "src": "/artifact/(.*)", "dest": "/artifact/$1" },

		{ "src": "/cz", "dest": "/cz/index.html" },
		{ "src": "/cz/", "dest": "/cz/index.html" },
		{ "src": "/cz/(.*)", "dest": "/cz/$1" },

		{ "src": "/validation", "dest": "/validation/index.html" },
		{ "src": "/validation/", "dest": "/validation/index.html" },
		{ "src": "/validation/(.*)", "dest": "/validation/$1" },

		{ "src": "/lobehub/iframe", "dest": "/lobehub/iframe/index.html" },
		{ "src": "/lobehub/iframe/", "dest": "/lobehub/iframe/index.html" },
		{ "src": "/lobehub/iframe/(.*)", "dest": "/lobehub/iframe/$1" },

		{ "src": "/api/auth/logout-everywhere", "dest": "/api/auth/logout-everywhere" },
		{ "src": "/api/auth/verify-email", "dest": "/api/auth/verify-email" },
		{ "src": "/api/auth/forgot-password", "dest": "/api/auth/forgot-password" },
		{ "src": "/api/auth/reset-password", "dest": "/api/auth/reset-password" },
		{ "src": "/api/auth/resend-verification", "dest": "/api/auth/resend-verification" },

		{ "src": "/api/llm/anthropic", "dest": "/api/llm/anthropic.js" },
		{ "src": "/api/agents/([^/]+)/usage", "dest": "/api/agents/[id]/usage?id=$1" },
		{ "src": "/dashboard/usage", "dest": "/dashboard/usage.html" },
		{ "src": "/api/erc8004/hydrate", "dest": "/api/erc8004/hydrate.js" },
		{ "src": "/api/erc8004/import", "dest": "/api/erc8004/import.js" },

		{ "src": "/api/dca-strategies/([^/]+)", "dest": "/api/dca-strategies?id=$1" },
		{ "src": "/api/dca-strategies", "dest": "/api/dca-strategies" },

		{ "src": "/api/billing/summary", "dest": "/api/billing/summary" },

		{ "src": "/my-agents", "dest": "/my-agents/index.html" },
		{ "src": "/my-agents/", "dest": "/my-agents/index.html" },
		{ "src": "/my-agents/(.*)", "dest": "/my-agents/$1" },
		{ "src": "/discover", "dest": "/discover/index.html" },
		{ "src": "/discover/", "dest": "/discover/index.html" },
		{ "src": "/discover/(.*)", "dest": "/discover/$1" },

		{ "src": "/api/(.*)", "dest": "/api/$1" },

		{
			"src": "/agent-3d/([0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9.-]+)?)/(.*)",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable",
				"access-control-allow-origin": "*",
				"access-control-allow-methods": "GET, HEAD, OPTIONS",
				"cross-origin-resource-policy": "cross-origin",
				"timing-allow-origin": "*"
			},
			"dest": "/agent-3d/$1/$2"
		},
		{
			"src": "/agent-3d/(latest|[0-9]+|[0-9]+\\.[0-9]+)/(.*)",
			"headers": {
				"cache-control": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400",
				"access-control-allow-origin": "*",
				"access-control-allow-methods": "GET, HEAD, OPTIONS",
				"cross-origin-resource-policy": "cross-origin",
				"timing-allow-origin": "*"
			},
			"dest": "/agent-3d/$1/$2"
		},
		{
			"src": "/agent-3d/versions\\.json",
			"headers": {
				"cache-control": "public, max-age=60, s-maxage=60",
				"access-control-allow-origin": "*"
			},
			"dest": "/agent-3d/versions.json"
		},

		{
			"src": "/assets/(.*)",
			"headers": { "cache-control": "max-age=604800, public" },
			"dest": "/assets/$1"
		},
		{
			"src": "/\\.well-known/(.*)",
			"headers": { "cache-control": "max-age=86400, public" },
			"dest": "/.well-known/$1"
		},
		{ "src": "/robots.txt", "dest": "/robots.txt" },
		{ "src": "/sitemap.xml", "dest": "/sitemap.xml" },
		{ "src": "/app", "dest": "/app.html" },
		{ "src": "/features.html", "status": 301, "headers": { "Location": "/features" } },
		{ "src": "/features", "dest": "/features/index.html" },
		{ "src": "/features/", "dest": "/features/index.html" },
		{ "src": "/features/(.*)", "dest": "/features/$1" },
		{ "src": "/create", "dest": "/create.html" },
		{ "src": "/create/", "dest": "/create.html" },
		{ "src": "/", "dest": "/home.html" },
		{ "src": "/home", "status": 301, "headers": { "Location": "/" } },
		{ "src": "/explore", "status": 301, "headers": { "Location": "/discover" } },
		{ "src": "/explore/", "status": 301, "headers": { "Location": "/discover" } },
		{
			"src": "/a/(\\d+)/(\\d+)/embed",
			"headers": {
				"content-security-policy": "frame-ancestors *",
				"x-content-type-options": "nosniff",
				"referrer-policy": "strict-origin-when-cross-origin",
				"permissions-policy": "microphone=(self), camera=(self), xr-spatial-tracking=*"
			},
			"dest": "/a-embed.html"
		},
		{ "src": "/a/(\\d+)/(\\d+)", "dest": "/api/a-page?chain=$1&id=$2" },
		{ "src": "/a/(.*)", "dest": "/app.html" },
		{ "src": "/(.*)", "dest": "/$1" }
	],
	"crons": [
		{ "path": "/api/cron/erc8004-crawl", "schedule": "*/15 * * * *" },
		{ "path": "/api/cron/index-delegations", "schedule": "*/5 * * * *" },
		{ "path": "/api/cron/run-dca", "schedule": "0 * * * *" },
		{ "path": "/api/cron/run-subscriptions", "schedule": "0 * * * *" }
	]
}
