{
    "public": true,
    "routes": [
        { "src": "/\\.well-known/oauth-authorization-server", "dest": "/api/wk-oauth-authorization-server" },
        { "src": "/\\.well-known/oauth-protected-resource",  "dest": "/api/wk-oauth-protected-resource" },
        { "src": "/api/mcp/\\.well-known/oauth-protected-resource", "dest": "/api/wk-oauth-protected-resource" },

        { "src": "/oauth/authorize",     "dest": "/api/oauth/authorize" },
        { "src": "/oauth/consent",       "dest": "/api/oauth/authorize" },
        { "src": "/oauth/token",         "dest": "/api/oauth/token" },
        { "src": "/oauth/register",      "dest": "/api/oauth/register" },
        { "src": "/oauth/revoke",        "dest": "/api/oauth/revoke" },
        { "src": "/oauth/introspect",    "dest": "/api/oauth/introspect" },

        { "src": "/login",               "dest": "/public/login.html" },
        { "src": "/register",            "dest": "/public/register.html" },
        { "src": "/dashboard",           "dest": "/public/dashboard/index.html" },
        { "src": "/dashboard/",          "dest": "/public/dashboard/index.html" },
        { "src": "/dashboard/(.*)",      "dest": "/public/dashboard/$1" },

        { "src": "/api/agents/me",        "dest": "/api/agents" },
        { "src": "/api/agents/([^/]+)/wallet", "dest": "/api/agents/[id]" },
        { "src": "/api/agents/([^/]+)",  "dest": "/api/agents/[id]" },
        { "src": "/api/agents",          "dest": "/api/agents" },
        { "src": "/api/agent-actions",   "dest": "/api/agent-actions" },
        { "src": "/api/agent-memory/([^/]+)", "dest": "/api/agent-memory" },
        { "src": "/api/agent-memory",    "dest": "/api/agent-memory" },
        { "src": "/agent/([^/]+)/embed", "dest": "/public/agent/embed.html" },
        { "src": "/agent/([^/]+)",       "dest": "/public/agent/index.html" },
        { "src": "/agent",               "dest": "/public/agent/index.html" },
        { "src": "/api/(.*)",            "dest": "/api/$1" },

        {
            "src": "/assets/(.*)",
            "headers": { "cache-control": "max-age=604800, public" },
            "dest": "/assets/$1"
        },
        {
            "src": "/\\.well-known/(.*)",
            "headers": { "cache-control": "max-age=86400, public" },
            "dest": "/public/.well-known/$1"
        },
        { "src": "/robots.txt",          "dest": "/public/robots.txt" },
        { "src": "/sitemap.xml",         "dest": "/public/sitemap.xml" },
        { "src": "/features",            "dest": "/features.html" },
        { "src": "/(.*)",                "dest": "/public/$1" }
    ]
}
